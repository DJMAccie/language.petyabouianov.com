Options -Indexes
RewriteEngine On

RewriteCond %{HTTP_HOST} !^language\.petyabouianov\.com$ [OR]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://language.petyabouianov.com%{REQUEST_URI} [R=301,L]

RewriteRule ^index\.html$ https://language.petyabouianov.com/ [R=301,L,NC]
RewriteRule ^nihongo-studio\.html$ https://language.petyabouianov.com/nihongo-studio [R=301,L,NC]
RewriteRule ^bahasa-studio\.html$ https://language.petyabouianov.com/bahasa-studio [R=301,L,NC]
RewriteRule ^italia-studio\.html$ https://language.petyabouianov.com/italia-studio [R=301,L,NC]

RewriteCond %{THE_REQUEST} \s/+([A-Za-z0-9_-]+)\.html[\s?] [NC]
RewriteRule ^([A-Za-z0-9_-]+)\.html$ https://language.petyabouianov.com/$1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([A-Za-z0-9_-]+)$ $1.html [L]

<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header always set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.php$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>
</IfModule>

<FilesMatch "\.(json|csv|env|log|config\.php|py|bak|sql)$">
  Require all denied
</FilesMatch>
<Files "error_log">
  Require all denied
</Files>
